# preciousmetalscharts — Apache config for Vimexx (public_html)
# -----------------------------------------------------------------------------
# Goal: make the clean, extensionless URLs used in the canonical tags + sitemap
# (e.g. /gold-ira) resolve to the real .html files, without touching real assets
# like /prices.json, /robots.txt, /sitemap.xml (those are served as-is).
# -----------------------------------------------------------------------------

Options -MultiViews
RewriteEngine On

# -----------------------------------------------------------------------------
# Canonical origin: force HTTPS + non-www so every page has ONE address.
# www.* and http://* issue a single 301 to https://preciousmetalscharts.com/...
# (matches the canonical tags + sitemap). Does not affect the live.* subdomain
# (its host isn't "www", and it keeps its own https).
# -----------------------------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
# Force HTTPS only when the upstream proxy explicitly reports plain http.
# (Vimexx terminates SSL upstream, so %{HTTPS} reads "off" even on https — using
# it here would redirect https→https forever. X-Forwarded-Proto=http is loop-safe.)
RewriteCond %{HTTP:X-Forwarded-Proto} =http [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# If the requested path is NOT an existing file or directory, but the same name
# with a .html extension IS a real file, serve that file. So /gold-ira -> gold-ira.html.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Branded 404 (keeps the 404 status code; the page itself is noindex).
ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# Caching — repeat visitors shouldn't re-download what hasn't changed.
# HTML: short (deploys are occasional). History JSON: longer (updates once/day).
# prices.json: never cache (refreshes ~every 10 min and must stay fresh).
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # HTML always revalidates with the server, so a deploy shows immediately (no stale page).
  # The browser keeps a copy but checks "changed?" each load → tiny 304 if unchanged, fresh if not.
  # CSS/JS are version-busted (?v=N), so they update the moment the HTML points to a new version.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  <FilesMatch "\.json$">
    Header set Cache-Control "public, max-age=3600"
    # Allow the live. subdomain (and embedders, with attribution) to read our price/history JSON.
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
  <FilesMatch "\.(woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    # Allow the live. subdomain to use the self-hosted fonts cross-origin.
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
  # The live price snapshot must always be fresh — override the .json rule above.
  <Files "prices.json">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </Files>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Brotli compression when the server supports it (no-op otherwise; gzip stays on).
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json image/svg+xml application/xml
</IfModule>
